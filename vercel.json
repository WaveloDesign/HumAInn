{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "public/index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/analyze", "dest": "/api/analyze.js" },
    { "src": "/api/humanize", "dest": "/api/humanize.js" },
    { "src": "/api/score", "dest": "/api/score.js" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ]
}
